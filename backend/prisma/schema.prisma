generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditScopeType {
  DEPARTMENT
  LOCATION
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  OVERDUE_RETURN_ALERT
  AUDIT_DISCREPANCY_FLAGGED
  ROLE_CHANGED
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  passwordHash        String
  name                String
  phone               String?
  role                Role                 @default(EMPLOYEE)
  departmentId        Int?
  status              RecordStatus         @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  department          Department?          @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments   Department[]         @relation("DepartmentHead")
  allocations         AssetAllocation[]    @relation("HolderUser")
  requestedTransfers  TransferRequest[]    @relation("TransferRequester")
  approvedTransfers   TransferRequest[]    @relation("TransferApprover")
  bookings            ResourceBooking[]
  maintenanceRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditAssignments    AuditAssignment[]
  auditChecks         AuditItem[]          @relation("AuditCheckedBy")
  auditCyclesCreated  AuditCycle[]         @relation("AuditCreatedBy")
  notifications       Notification[]
  activityLogs        ActivityLog[]

  @@index([departmentId])
}

model Department {
  id                 Int                  @id @default(autoincrement())
  name               String
  parentDepartmentId Int?
  headUserId         Int?
  status             RecordStatus         @default(ACTIVE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  parent             Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  children           Department[]         @relation("DepartmentHierarchy")
  head               User?                @relation("DepartmentHead", fields: [headUserId], references: [id])
  users              User[]               @relation("DepartmentUsers")
  assets             Asset[]
  allocations        AssetAllocation[]
  bookings           ResourceBooking[]

  @@index([parentDepartmentId])
  @@index([headUserId])
}

model AssetCategory {
  id                 Int          @id @default(autoincrement())
  name               String       @unique
  status             RecordStatus @default(ACTIVE)
  customFieldsSchema Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  assets             Asset[]
}

model Asset {
  id                  Int                  @id @default(autoincrement())
  tag                 String               @unique
  name                String
  categoryId          Int
  serialNumber        String               @unique
  acquisitionDate     DateTime?
  acquisitionCost     Decimal?             @db.Decimal(12, 2)
  condition           String
  location            String
  status              AssetStatus          @default(AVAILABLE)
  isSharedResource    Boolean              @default(false)
  photoPath           String?
  departmentId        Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  category            AssetCategory        @relation(fields: [categoryId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  allocations         AssetAllocation[]
  transferRequests    TransferRequest[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  files               UploadedFile[]

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
}

model AssetAllocation {
  id                   Int               @id @default(autoincrement())
  assetId              Int
  holderUserId         Int?
  holderDepartmentId   Int?
  allocatedAt          DateTime          @default(now())
  expectedReturnDate   DateTime?
  returnedAt           DateTime?
  returnConditionNotes String?
  isActive             Boolean           @default(true)
  asset                Asset             @relation(fields: [assetId], references: [id])
  holderUser           User?             @relation("HolderUser", fields: [holderUserId], references: [id])
  holderDepartment     Department?       @relation(fields: [holderDepartmentId], references: [id])
  transferRequests     TransferRequest[]

  @@index([assetId, isActive])
  @@index([holderUserId])
  @@index([holderDepartmentId])
}

model TransferRequest {
  id                 Int              @id @default(autoincrement())
  assetId            Int
  fromAllocationId   Int
  toUserId           Int?
  toDepartmentId     Int?
  status             TransferStatus   @default(REQUESTED)
  requestedByUserId  Int
  approvedByUserId   Int?
  rejectionReason    String?
  requestedAt        DateTime         @default(now())
  decidedAt          DateTime?
  asset              Asset            @relation(fields: [assetId], references: [id])
  fromAllocation     AssetAllocation  @relation(fields: [fromAllocationId], references: [id])
  requestedBy        User             @relation("TransferRequester", fields: [requestedByUserId], references: [id])
  approvedBy         User?            @relation("TransferApprover", fields: [approvedByUserId], references: [id])

  @@index([assetId])
  @@index([fromAllocationId])
  @@index([requestedByUserId])
  @@index([approvedByUserId])
}

model BookableResource {
  id        Int               @id @default(autoincrement())
  name      String
  type      String
  location  String
  status    RecordStatus      @default(ACTIVE)
  bookings  ResourceBooking[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ResourceBooking {
  id             Int              @id @default(autoincrement())
  resourceId     Int
  bookedByUserId Int
  departmentId   Int?
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus    @default(UPCOMING)
  createdAt      DateTime         @default(now())
  resource       BookableResource @relation(fields: [resourceId], references: [id])
  bookedBy       User             @relation(fields: [bookedByUserId], references: [id])
  department     Department?      @relation(fields: [departmentId], references: [id])

  @@index([resourceId, startTime, endTime])
  @@index([bookedByUserId])
  @@index([departmentId])
}

model MaintenanceRequest {
  id               Int               @id @default(autoincrement())
  assetId          Int
  raisedByUserId   Int
  issueDescription String            @db.Text
  priority         Priority          @default(MEDIUM)
  photoPath        String?
  status           MaintenanceStatus @default(PENDING)
  approvedByUserId Int?
  approvedAt       DateTime?
  rejectionReason  String?
  technicianName   String?
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  asset            Asset             @relation(fields: [assetId], references: [id])
  raisedBy         User              @relation("MaintenanceRaisedBy", fields: [raisedByUserId], references: [id])
  approvedBy       User?             @relation("MaintenanceApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([assetId])
  @@index([raisedByUserId])
  @@index([status])
}

model AuditCycle {
  id              Int              @id @default(autoincrement())
  name            String
  scopeType       AuditScopeType
  scopeValue      String
  startDate       DateTime
  endDate         DateTime
  status          AuditCycleStatus @default(OPEN)
  createdByUserId Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       User             @relation("AuditCreatedBy", fields: [createdByUserId], references: [id])
  assignments     AuditAssignment[]
  items           AuditItem[]

  @@index([createdByUserId])
}

model AuditAssignment {
  id           Int        @id @default(autoincrement())
  auditCycleId Int
  auditorUserId Int
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditor      User       @relation(fields: [auditorUserId], references: [id])

  @@unique([auditCycleId, auditorUserId])
  @@index([auditorUserId])
}

model AuditItem {
  id              Int         @id @default(autoincrement())
  auditCycleId    Int
  assetId         Int
  result          AuditResult @default(PENDING)
  notes           String?
  checkedAt       DateTime?
  checkedByUserId Int?
  auditCycle      AuditCycle  @relation(fields: [auditCycleId], references: [id])
  asset           Asset       @relation(fields: [assetId], references: [id])
  checkedBy       User?       @relation("AuditCheckedBy", fields: [checkedByUserId], references: [id])

  @@unique([auditCycleId, assetId])
  @@index([assetId])
  @@index([checkedByUserId])
}

model Notification {
  id                Int              @id @default(autoincrement())
  userId            Int
  type              NotificationType
  message           String
  isRead            Boolean          @default(false)
  relatedEntityType String?
  relatedEntityId   Int?
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  action      String
  entityType  String
  entityId    Int?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model UploadedFile {
  id         Int      @id @default(autoincrement())
  assetId    Int?
  path       String
  filename   String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())
  asset      Asset?   @relation(fields: [assetId], references: [id])

  @@index([assetId])
}
